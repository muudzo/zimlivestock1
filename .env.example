# ─── ZimLivestock Environment Variables ─────────────────────────────────────
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git!

# ── Paynow Credentials ────────────────────────────────────────────────────────
# Get these from the Paynow Merchant Portal:
# https://www.paynow.co.zw/merchant/management
PAYNOW_INTEGRATION_ID=your_integration_id_here
PAYNOW_INTEGRATION_KEY=your_integration_key_here

# ── Paynow Callback URLs ───────────────────────────────────────────────────────
# RESULT_URL: Paynow will POST payment status updates here (must be publicly accessible)
# Use ngrok for local development: e.g. https://abc123.ngrok.io/payments/webhook
PAYNOW_RESULT_URL=https://yourdomain.co.zw/payments/webhook

# RETURN_URL: Where to redirect the browser after a web payment attempt
PAYNOW_RETURN_URL=https://yourdomain.co.zw/payment-complete

# ── App Settings ──────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=true
