# ─── ZimLivestock Environment Variables ─────────────────────────────────────
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git!

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-or-service-role-key

# ── Paynow Credentials ──────────────────────────────────────────────────────
# Get these from https://www.paynow.co.zw/merchant/management
PAYNOW_INTEGRATION_ID=your_integration_id_here
PAYNOW_INTEGRATION_KEY=your_integration_key_here

# ── Paynow Callback URLs ────────────────────────────────────────────────────
# RESULT_URL: Paynow POSTs payment status here (must be publicly accessible)
PAYNOW_RESULT_URL=https://yourdomain.co.zw/payments/webhook
# RETURN_URL: Browser redirect after web payment
PAYNOW_RETURN_URL=https://yourdomain.co.zw/payment-complete

# ── App Settings ─────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=false
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
